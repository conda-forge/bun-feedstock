From: Pavel Zwerschke <pavelzw@gmail.com>
Date: Sat, 7 Feb 2026 21:47:43 +0100
Subject: [PATCH 08/12] don't use llvm toolchain

---
 cmake/tools/SetupLLVM.cmake | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/cmake/tools/SetupLLVM.cmake b/cmake/tools/SetupLLVM.cmake
index 9e17eb7..64e3f4f 100644
--- a/cmake/tools/SetupLLVM.cmake
+++ b/cmake/tools/SetupLLVM.cmake
@@ -1,3 +1,6 @@
+set(CMAKE_STRIP "$ENV{CMAKE_STRIP}" CACHE FILEPATH "Path to strip" FORCE)
+set(LLD_PROGRAM "$ENV{CMAKE_LLD}" CACHE FILEPATH "Path to lld" FORCE)
+return()
 
 set(DEFAULT_ENABLE_LLVM ON)
 
