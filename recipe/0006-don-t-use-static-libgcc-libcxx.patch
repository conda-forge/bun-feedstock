From a6215e2b5c8641b2a996818c1d595f353c0dc7da Mon Sep 17 00:00:00 2001
From: Pavel Zwerschke <pavelzw@gmail.com>
Date: Sat, 7 Feb 2026 21:43:12 +0100
Subject: [PATCH 06/12] don't use static libgcc, libcxx

---
 cmake/targets/BuildBun.cmake | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/cmake/targets/BuildBun.cmake b/cmake/targets/BuildBun.cmake
index 4eb32b2..cce35da 100644
--- a/cmake/targets/BuildBun.cmake
+++ b/cmake/targets/BuildBun.cmake
@@ -1123,8 +1123,8 @@ if(LINUX)
 
   if(NOT ABI STREQUAL "musl")
     target_link_options(${bun} PUBLIC
-      -static-libstdc++
-      -static-libgcc
+      -lstdc++
+      -lgcc
     )
   else()
     target_link_options(${bun} PUBLIC
